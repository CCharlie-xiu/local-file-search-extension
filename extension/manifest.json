{
  "manifest_version": 3,
  "name": "本地文件搜索",
  "version": "1.0.0",
  "description": "选中网页文字，实时搜索本地文件并显示上下文内容",
  "permissions": [
    "contextMenus",
    "storage",
    "nativeMessaging",
    "notifications",
    "clipboardWrite",
    "windows"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "本地文件搜索"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
